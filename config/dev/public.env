PORT=3000
CLIENT_PORT=5173
DEPLOYMENT=dev
DOCKER_CONTEXT=default
DATABASE_URL=file:./data/dev.db
BACKUP_DIR=./data/backup
APP_DOMAIN=localhost
APP_NAME=Flyerbot
APP_SLUG=flyerbot

# OAuth callback URLs (non-secret, environment-specific)
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback

# Workspace Versioning Service (non-secret, optional -- architecture-001
# §Versioning Service, this sprint's R1 one-repo default). Both empty by
# default: WORKSPACE_GIT_ROOT falls back to the app repo root,
# WORKSPACE_GIT_REMOTE unset means local-commit-only, no push attempted.
WORKSPACE_GIT_ROOT=
WORKSPACE_GIT_REMOTE=
