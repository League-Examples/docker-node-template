# Environment configuration.
# Generated by scripts/install.sh — do not commit this file.


# ---------------------------------------------------------------------------
# Docker contexts
# ---------------------------------------------------------------------------

# Docker context for local development (containers run here for dev and dev:docker)
DEV_DOCKER_CONTEXT=default

# Docker context for production deployment (deploy targets this)
PROD_DOCKER_CONTEXT=swarm1

# Production domain (used by Caddy labels in docker-compose.prod.yml)
APP_DOMAIN=myapp.jtlapp.net

# ---------------------------------------------------------------------------
# SOPS / age (secrets decryption)
# ---------------------------------------------------------------------------
# Set ONE of these so SOPS can find your age key:
#   SOPS_AGE_KEY=AGE-SECRET-KEY-...        (inline secret key)
#   SOPS_AGE_KEY_FILE=/path/to/keys.txt    (path to key file)
#
# If neither is set and ~/.config/sops/age/keys.txt exists, SOPS finds it
# automatically — but npm scripts that source this file won't export it.
# The install script fills in the appropriate value below.

#:SOPS_AGE_KEY_FILE=

