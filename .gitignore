# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Environment / secrets
.env
.env.local
.env.*.local
*.agekey

# Config (local overrides are gitignored; secrets.env is SOPS-encrypted and committed)
config/local/

# Prisma
.prisma/
server/src/generated/
server/prisma/*.db
server/prisma/*.db-journal

# OS
.DS_Store
Thumbs.db

# Editors (local settings only; .vscode/ is committed for shared config)
*.swp
*.swo
*~

# Test output
coverage/
test-results/
playwright-report/
blob-report/

# Logs
*.log
pids/
*.pid
*.seed

# Backup data
data/
# dotconfig — assembled env files contain decrypted secrets
.env.*
!.env.example

# Workspace filesystem (architecture-001 §File-System Layout) — the
# directory *tree* is committed as scaffold (see .gitkeep placeholders
# under server/workspace/), but _dir.json mirror files are derived from
# WorkspaceDirectory rows in the (gitignored, per-environment) SQLite DB —
# see server/src/services/workspaceDirectorySync.ts (D6) and
# server/src/scripts/scaffold-workspace-directories.ts. Committing them
# would drift out of step with a DB that isn't itself versioned; regenerate
# via the scaffold script instead.
server/workspace/**/_dir.json
